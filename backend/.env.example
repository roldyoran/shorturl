# Cloudflare D1 — obtenidos tras ejecutar: bunx wrangler d1 create shorturl-db
CLOUFLARE_D1_DATABASES_BINDING=your_binding_name
CLOUFLARE_D1_DATABASES_NAME=your_database_name

SERVICE_ADMIN_API_KEY=your_service_admin_api_key

# Credenciales para drizzle-kit (push/migrate al D1 remoto)
# Obtén en: https://dash.cloudflare.com -> Workers & Pages -> Overview -> Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id
# Mismo valor que CLOUDFLARE_DATABASE_ID
CLOUDFLARE_DATABASE_ID=your_database_id
# API Token con permisos D1: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_D1_TOKEN=your_d1_api_token
